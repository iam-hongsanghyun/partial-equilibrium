# Copy to .env and edit as needed. This project does not auto-load .env
# (no dotenv loader is wired in — see src/pe/registry/config.py); export
# these into your shell / deployment environment however you normally do
# (`export $(grep -v '^#' .env | xargs)`, `uv run --env-file .env ...`, your
# platform's env-var settings, ...). Every var here is read via os.environ
# with the documented default, so nothing below is required to run locally.

# --- Model registry storage backend (src/pe/registry/) ---------------------

# Which StorageBackend persists user-saved models (pe.model_store). One of:
# "sqlite" (default, stdlib sqlite3, no extra service required) or
# "supabase" (interface-only stub today — see
# src/pe/registry/supabase_backend.py; every method raises NotImplementedError
# until a real Supabase project is wired up).
PE_REGISTRY_BACKEND=sqlite

# Where the SQLite registry file lives when PE_REGISTRY_BACKEND=sqlite.
# Relative paths resolve against the project root. Defaults to
# database/registry.sqlite (the database/ directory is created on first use;
# the .sqlite file itself is gitignored — it is runtime data, the schema
# lives in code).
PE_REGISTRY_DB_PATH=database/registry.sqlite

# Supabase project credentials — read only when PE_REGISTRY_BACKEND=supabase.
# Unused today (SupabaseBackend is an interface sketch, not a live backend).
PE_SUPABASE_URL=
PE_SUPABASE_KEY=
